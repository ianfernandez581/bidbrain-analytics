# grid-core credentials — copy to .env and fill in. NEVER commit .env.
# Each connector reads only what it needs; missing vars => that platform is
# reported NOT CONFIGURED (never crashes the others).

# --- Google Ads (SYNC) ------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=      # MCC id, digits only
GOOGLE_ADS_CUSTOMER_IDS=           # comma-separated client account ids, digits only
GOOGLE_ADS_API_VERSION=v23         # bump as Google's monthly releases advance

# --- The Trade Desk (CREATE-POLL) ------------------------------------------
# Needs your account team to enable 3rd-party My Reports API for the Partner.
TTD_API_USERNAME=
TTD_API_PASSWORD=
TTD_PARTNER_ID=
TTD_ADVERTISER_IDS=                # optional, comma-separated; empty = all
TTD_REPORT_TEMPLATE_ID=            # optional saved template to run

# --- Meta (SYNC) ------------------------------------------------------------
META_ACCESS_TOKEN=                 # system-user token
META_AD_ACCOUNT_IDS=               # comma-separated act_XXXX ids

# --- LinkedIn (SYNC) --------------------------------------------------------
LINKEDIN_ACCESS_TOKEN=             # OAuth2, scope r_ads_reporting
LINKEDIN_ACCOUNT_IDS=

# --- Reddit (SYNC) ----------------------------------------------------------
REDDIT_ACCESS_TOKEN=
REDDIT_ACCOUNT_IDS=

# --- DV360 (CREATE-POLL, Bid Manager) --------------------------------------
# Reuses the Google OAuth block above; add partner/advertiser scoping:
DV360_PARTNER_ID=
DV360_ADVERTISER_IDS=

# --- Brain V3 (historical upload / LLM extraction) ---
# Structured extraction + challenger verification (optional — pipeline falls back
# to an offline heuristic + rule-based verifier when unset).
ANTHROPIC_API_KEY=
# LlamaParse for PDF/PPTX/DOCX parsing. Get one at https://cloud.llamaindex.ai/
# (optional — PDF/PPTX show a mock parse when unset; XLSX/CSV parse natively regardless).
LLAMA_CLOUD_API_KEY=
