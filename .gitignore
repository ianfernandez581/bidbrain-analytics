# Secrets / keys (NEVER commit)
*.p8
*.pub
*.pem
*.key
*-key.json
*credentials*.json
service-account*.json
.env
# Bare-named private keys (no extension) — these slipped past *.key before
*_key
mirror_key
id_rsa
id_ecdsa
id_ed25519

# Local data & logs
chunks/
*.log
# Raw client report exports (manual drops -> seeded into BigQuery, never committed)
clients/*/data/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.ndjson
_run/

# Claude Code harness / session state (not part of the project)
.claude/

# Per-developer branch name remembered by scripts/push-branch.ps1 (machine-local)
scripts/.devname
