# ─────────────────────────────────────────────────────────────────────────────
# api-probe secrets.  Copy to .env and fill in only the platforms you can.
# Any platform whose required vars are blank is reported "NOT CONFIGURED"
# (the probe skips it and prints setup instructions instead of failing).
# READ-ONLY reporting creds only — this tool never makes write/mutate calls.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Google Ads ────────────────────────────────────────────────────────────
# OAuth2 desktop/web client + a developer token from the API Center.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# The MCC (manager) account id, digits only, no dashes.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# The account you actually want spend for (defaults to LOGIN_CUSTOMER_ID).
GOOGLE_ADS_CUSTOMER_ID=
# API version segment of the URL. Bump if Google deprecates it (e.g. v18, v19, v20).
GOOGLE_ADS_API_VERSION=v18

# ── 2. Meta (Facebook/Instagram) Marketing API ───────────────────────────────
# A long-lived System User token (Business Manager > System Users).
META_ACCESS_TOKEN=
# Ad account id WITHOUT the "act_" prefix (just the digits).
META_AD_ACCOUNT_ID=
META_API_VERSION=v19.0

# ── 3. LinkedIn Marketing API ─────────────────────────────────────────────────
# OAuth2 access token with the r_ads_reporting scope.
LINKEDIN_ACCESS_TOKEN=
# Sponsored ad account id (digits only).
LINKEDIN_AD_ACCOUNT_ID=
# Versioned API header, format YYYYMM (LinkedIn ships monthly versions).
LINKEDIN_API_VERSION=202401

# ── 4. Reddit Ads API ─────────────────────────────────────────────────────────
# OAuth2 "web app" client + a refresh token minted with ads.read scope.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
# Ad account id (the a2_XXXX / t2_XXXX id from the Reddit Ads dashboard).
REDDIT_AD_ACCOUNT_ID=
# Sent as the User-Agent (Reddit requires a descriptive one).
REDDIT_USER_AGENT=bidbrain-api-probe/0.1 (by /u/yourname)

# ── 5. The Trade Desk ─────────────────────────────────────────────────────────
# API user credentials (NOT your UI login) issued by your TTD rep.
TTD_API_USERNAME=
TTD_API_PASSWORD=
TTD_PARTNER_ID=
# Sandbox: https://api-sandbox.thetradedesk.com/v3 — Prod is the default below.
TTD_API_BASE=https://api.thetradedesk.com/v3

# ── 6. DV360 (Display & Video 360) ────────────────────────────────────────────
# OAuth2 client with the display-video + doubleclickbidmanager scopes.
# (Can be the SAME Google OAuth client as Google Ads if it has both scopes.)
DV360_CLIENT_ID=
DV360_CLIENT_SECRET=
DV360_REFRESH_TOKEN=
DV360_PARTNER_ID=
DV360_ADVERTISER_ID=
